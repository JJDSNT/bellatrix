@@ -190,9 +197,10 @@ void MainLoop()
                     {
                         level = ipl_level;
                     }
-                }           
+                }
 #endif
             }
+#endif /* BELLATRIX */
 
             /* Get SR and test the IPL mask value */
             SR = getSR();
@@ -236,6 +244,49 @@ void MainLoop()
                 SR &= ~SR_IPL;
                 SR |= ((level & 7) << SRB_IPL);
 
+
+#ifdef BELLATRIX
+                {
+                    /* kprintf clobbers x18 (M68K PC) — save/restore around every call. */
+                    uint64_t _x18_save;
+                    uint32_t _old_pc, _old_sp, _vec_addr, _vec_val;
+
+                    asm volatile("mov %0, x18" : "=r"(_x18_save));
+                    _old_pc   = (uint32_t)_x18_save;
+                    _old_sp   = (uint32_t)sp;
+                    _vec_addr = ctx->VBR + (uint32_t)vector;
+                    _vec_val  = 0;
+                    asm volatile("ldr %w0, [%1, %2]" : "=r"(_vec_val) : "r"(ctx->VBR), "r"(vector));
+
+                    kprintf("[EXC-REQ] kind=irq lvl=%d vec=%04x old_pc=%08x old_sr=%04x old_sp=%08x vec_addr=%08x vec_val=%08x\n",
+                            level, (unsigned)vector, _old_pc, (unsigned)SRcopy, _old_sp, _vec_addr, _vec_val);
+                    asm volatile("mov x18, %0" :: "r"(_x18_save)); /* restore PC */
+
+                    /* Push exception frame */
+                    asm volatile("strh %w1, [%0, #-8]!":"=r"(sp):"r"(SRcopy),"0"(sp));
+                    asm volatile("str %w1, [%0, #2]"::"r"(sp),"r"(PC));
+                    asm volatile("strh %w1, [%0, #6]"::"r"(sp),"r"(vector));
+
+                    /* Set SR */
+                    setSR(SR);
+                    asm volatile("mov x18, %0" :: "r"(_x18_save)); /* setSR may clobber */
+
+                    /* Get VBR */
+                    vbr = ctx->VBR;
+
+                    /* Load new PC from vector table */
+                    asm volatile("ldr %w0, [%1, %2]":"=r"(PC):"r"(vbr),"r"(vector));
+
+                    /* Capture new PC before kprintf trashes x18 */
+                    uint64_t _x18_new;
+                    asm volatile("mov %0, x18" : "=r"(_x18_new));
+                    uint32_t _new_pc = (uint32_t)_x18_new;
+
+                    kprintf("[EXC-PC] old_pc=%08x new_pc=%08x sr=%04x sp=%08x\n",
+                            _old_pc, _new_pc, (unsigned)SR, (uint32_t)sp);
+                    asm volatile("mov x18, %0" :: "r"(_x18_new)); /* restore new PC */
+                }
+#else
                 /* Push exception frame */
                 asm volatile("strh %w1, [%0, #-8]!":"=r"(sp):"r"(SRcopy),"0"(sp));
                 asm volatile("str %w1, [%0, #2]"::"r"(sp),"r"(PC));
@@ -248,7 +299,8 @@ void MainLoop()
                 vbr = ctx->VBR;
 
